# Internal URL the Medusa backend uses to notify the storefront to revalidate its
# Next.js menu cache after any menu change (server-to-server, no CORS issues).
# Docker: http://storefront:8000  |  Local dev: http://localhost:8000 (default)
STOREFRONT_INTERNAL_URL=http://localhost:8000

# PayPal payment configuration encryption key (32-byte base64-encoded)
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
PAYPAL_CONFIG_ENCRYPTION_KEY=
