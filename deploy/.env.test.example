# ==============================================================
# 测试环境 .env 模板
# 复制为 .env 后填写真实值：cp .env.test.example .env
# ==============================================================

# ── PostgreSQL ─────────────────────────────────────────────────
POSTGRES_USER=medusa
POSTGRES_PASSWORD=change_me_strong_password_123
POSTGRES_DB=medusa_db

# ── Redis ──────────────────────────────────────────────────────
REDIS_PASSWORD=change_me_redis_password_456


# ── Admin 镜像 Tag ───────────────────────────────────────────
# 填写腾讯云镜像仓库中的实际 tag
IMAGE_TAG=main-main-20260331-651a36c215c4844556cf71db6248d2ae019ea5db

TENCENT_REGISTRY_PASSWORD=Linzhiqiang0316!
JWT_SECRET=your-jwt-secret
COOKIE_SECRET=your-cookie-secret

# ── CORS ──────────────────────────────────────────────────────
STORE_CORS=https://www.wolzq.com
ADMIN_CORS=https://admin.wolzq.com
AUTH_CORS=https://admin.wolzq.com,https://www.wolzq.com

# ── 文件上传 URL 前缀 ──────────────────────────────────────────
# Medusa 生成图片 URL 时使用此地址，必须是浏览器可访问的公网地址
BACKEND_URL=https://admin.wolzq.com/uploads

# ── Storefront ─────────────────────────────────────────────────
# NEXT_PUBLIC_* 变量在 docker build 时通过 --build-arg 烘入镜像
# 运行时可通过容器环境变量覆盖（仅对非 NEXT_PUBLIC_ 变量有效）
NEXT_PUBLIC_MEDUSA_BACKEND_URL=http://170.106.111.51:9000
NEXT_PUBLIC_BASE_URL=http://170.106.111.51
NEXT_PUBLIC_DEFAULT_REGION=cn
# 先启动 Admin 后，从管理后台 → 设置 → API密钥 中获取 Publishable Key
NEXT_PUBLIC_MEDUSA_PUBLISHABLE_KEY=pk_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
REVALIDATE_SECRET=your-revalidate-secret