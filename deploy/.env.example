# ==============================================================
# 生产环境变量配置模板
# 复制为 .env 后填写真实值：cp .env.example .env
# ⚠️ .env 文件绝对不能提交到 Git！
# ==============================================================

# ── GitHub 镜像仓库 ────────────────────────────────────────────
# 格式：your-github-username/your-repo-name（全小写）
GITHUB_REPO=your-github-username/your-repo-name

# 部署的镜像版本标签（GitHub Actions 会自动写入，手动部署时可设为 latest）
IMAGE_TAG=latest

# ── PostgreSQL ─────────────────────────────────────────────────
POSTGRES_USER=medusa
POSTGRES_PASSWORD=change_me_strong_password_123
POSTGRES_DB=medusa_db

# ── Redis ──────────────────────────────────────────────────────
REDIS_PASSWORD=change_me_redis_password_456

# ── Medusa 安全密钥（至少 32 位随机字符串）─────────────────────
# 生成命令：openssl rand -base64 32
JWT_SECRET=your_jwt_secret_at_least_32_chars_long
COOKIE_SECRET=your_cookie_secret_at_least_32_chars_long

# ── Medusa CORS（逗号分隔，生产环境填真实域名）──────────────────
# 前端访问后端 API
STORE_CORS=https://yourdomain.com,https://www.yourdomain.com
# Admin 面板访问后端
ADMIN_CORS=https://api.yourdomain.com
# 认证服务 CORS
AUTH_CORS=https://yourdomain.com,https://api.yourdomain.com

# ── Next.js 前端 ───────────────────────────────────────────────
# 前端调用后端 API 的地址
NEXT_PUBLIC_MEDUSA_BACKEND_URL=https://api.yourdomain.com
# 前端自身的域名
NEXT_PUBLIC_BASE_URL=https://yourdomain.com
# 默认区域
NEXT_PUBLIC_DEFAULT_REGION=cn
# Medusa Publishable API Key（在 Medusa Admin > Settings > API Keys 中创建）
NEXT_PUBLIC_MEDUSA_PUBLISHABLE_KEY=your_publishable_api_key
# ISR 缓存重验证密钥
REVALIDATE_SECRET=change_me_revalidate_secret

TENCENT_REGISTRY_PASSWORD=Linzhiqiang0316!
JWT_SECRET=your-jwt-secret
COOKIE_SECRET=your-cookie-secret
STORE_CORS=http://localhost:8000
ADMIN_CORS=http://localhost:9000
AUTH_CORS=http://localhost:9000